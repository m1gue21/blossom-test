# Server
PORT=4000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rick_morty_db
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rick and Morty API
RICK_MORTY_API_URL=https://rickandmortyapi.com/api

# Sync job (cron / npm run job:sync-characters): pause between paginated requests (ms). Increase if you see 429.
# RICK_MORTY_SYNC_PAGE_DELAY_MS=450
# RICK_MORTY_SYNC_MAX_RETRIES=12
